# ─────────────────────────────────────────────────────────────
# FisioForme — variáveis de ambiente (copie para .env)
# ─────────────────────────────────────────────────────────────

# Supabase — pegue em Project Settings > API e > Database
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...anon
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role
# Connection string (Project Settings > Database > Connection string > URI / "Session" pooler)
DATABASE_URL=postgresql://postgres.YOUR-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Backend
PORT=4000
NODE_ENV=development
# URL do front (para CORS). Em produção use a URL do Render.
WEB_ORIGIN=http://localhost:5173
# Bucket de anexos no Supabase Storage
STORAGE_BUCKET=attachments

# ─────────────────────────────────────────────────────────────
# Frontend (Vite) — precisam do prefixo VITE_
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon
VITE_API_URL=http://localhost:4000
VITE_STORAGE_BUCKET=attachments
